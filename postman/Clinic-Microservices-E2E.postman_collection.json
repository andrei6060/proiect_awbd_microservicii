{
  "info": {
    "_postman_id": "c1a9f0e2-7b3d-4f10-9a21-clinic000e2e",
    "name": "Clinic Microservices E2E",
    "description": "Generated from the actual @RestController + @RequestBody DTOs of auth-service and business-service (the endpoints the API gateway routes to). All requests go through the gateway via {{baseUrl}} = http://localhost:8080/api/v1.\n\nFlow: run Auth > 'Authenticate Doctor' and 'Authenticate User' first; their test scripts store the JWT in {{doctorToken}} / {{userToken}}. Protected requests send Bearer {{doctorToken}} or {{userToken}} according to the endpoint's @PreAuthorize role.\n\nSome happy-path writes depend on existing data (DB-generated ids are not returned by the API): acceptAppointment / deleteAppointment / notGoodDoctor use {{appointmentId}}, deleteReview uses {{reviewId}}, give/file use {{patientId}}/{{doctorId}}. Set those variables to real ids, or expect the documented non-200 in those cases. The Error Cases folder is fully deterministic.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Doctor (POST /auth/register)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 202 Accepted', function () { pm.response.to.have.status(202); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Greg\",\n  \"lastname\": \"House\",\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{doctorPassword}}\",\n  \"specialization\": \"CARDIOLOGIE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "auth", "register" ] },
            "description": "RegistrationRequestDto { firstname, lastname, email, password(>=10), specialization?: ORL|GINECOLOGIE|CARDIOLOGIE|ORTOPEDIE|ONCOLOGIE|PEDIATRIE }. With specialization -> DOCTOR account. Public."
          }
        },
        {
          "name": "Register User/Patient (POST /auth/register)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 202 Accepted', function () { pm.response.to.have.status(202); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"John\",\n  \"lastname\": \"Doe\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "auth", "register" ] },
            "description": "No specialization -> USER (patient) account. Public."
          }
        },
        {
          "name": "Activate Account (GET /auth/activateUser)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Requires the real 6-digit code emailed to MailDev (http://localhost:1080).",
                  "// Paste it into the {{activationToken}} variable. A wrong/expired code returns 500.",
                  "pm.test('Status is 200 (valid code)', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/activateUser?token={{activationToken}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "activateUser" ],
              "query": [ { "key": "token", "value": "{{activationToken}}" } ]
            },
            "description": "Activates the account with the emailed code. Public."
          }
        },
        {
          "name": "Authenticate Doctor (POST /auth/authenticate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('JWT token returned', function () { pm.expect(body.token).to.be.a('string'); });",
                  "pm.environment.set('doctorToken', body.token);",
                  "pm.collectionVariables.set('doctorToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{doctorPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/authenticate", "host": [ "{{baseUrl}}" ], "path": [ "auth", "authenticate" ] },
            "description": "AuthenticationRequestDto { email, password }. Saves response.token to {{doctorToken}}. Account must be activated first."
          }
        },
        {
          "name": "Authenticate User (POST /auth/authenticate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('JWT token returned', function () { pm.expect(body.token).to.be.a('string'); });",
                  "pm.environment.set('userToken', body.token);",
                  "pm.collectionVariables.set('userToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/authenticate", "host": [ "{{baseUrl}}" ], "path": [ "auth", "authenticate" ] },
            "description": "Saves response.token to {{userToken}}."
          }
        },
        {
          "name": "Delete User (DELETE /auth/deleteUser) [DOCTOR]",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// 200 when the user id exists; deleting a non-existent id returns 500.",
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{doctorToken}}", "type": "string" } ] },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/deleteUser?token={{deleteUserId}}",
              "host": [ "{{baseUrl}}" ],
              "path": [ "auth", "deleteUser" ],
              "query": [ { "key": "token", "value": "{{deleteUserId}}" } ]
            },
            "description": "Query param 'token' is the Integer user id to delete. @PreAuthorize DOCTOR."
          }
        }
      ]
    },
